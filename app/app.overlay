/ {
    aliases {
        enc10sw = &enc10sw;
        enc10a = &enc10a;
        enc10b = &enc10b;
        enc13sw = &enc13sw;
        enc13b = &enc13b;
        enc13a = &enc13a;
        enc14sw = &enc14sw;
        enc14b = &enc14b;
        enc14a = &enc14a;
        mux0 = &cd4067_0;
        mux1 = &cd4067_1;
        mux2 = &cd4067_2;
        mux3 = &cd4067_3;
    };

    encoder_inputs: encoder_inputs {
        compatible = "gpio-keys";

        enc10sw: enc10sw_gpio {
            gpios = <&gpiob 2 GPIO_ACTIVE_LOW>;
        };

        enc10a: enc10a_gpio {
            gpios = <&gpiob 1 GPIO_ACTIVE_LOW>;
        };

        enc10b: enc10b_gpio {
            gpios = <&gpiob 15 GPIO_ACTIVE_LOW>;
        };

        enc13sw: enc13sw_gpio {
            gpios = <&gpiob 13 GPIO_ACTIVE_LOW>;
        };

        enc13b: enc13b_gpio {
            gpios = <&gpioc 2 GPIO_ACTIVE_LOW>;
        };

        enc13a: enc13a_gpio {
            gpios = <&gpioc 3 GPIO_ACTIVE_LOW>;
        };

        enc14sw: enc14sw_gpio {
            gpios = <&gpioc 0 GPIO_ACTIVE_LOW>;
        };

        enc14b: enc14b_gpio {
            gpios = <&gpioc 1 GPIO_ACTIVE_LOW>;
        };

        enc14a: enc14a_gpio {
            gpios = <&gpioh 0 GPIO_ACTIVE_LOW>;
        };
    };

    cd4067_0: cd4067_mux {
        compatible = "vnd,cd4067-gpio-mux";
        status = "okay";
        select-gpios = <&gpiob 5 GPIO_ACTIVE_HIGH>,
                       <&gpiob 4 GPIO_ACTIVE_HIGH>,
                       <&gpiob 10 GPIO_ACTIVE_HIGH>,
                       <&gpioa 8 GPIO_ACTIVE_HIGH>;
        sig-gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;
    };

    cd4067_1: cd4067_mux_1 {
        compatible = "vnd,cd4067-gpio-mux";
        status = "okay";
        select-gpios = <&gpiob 5 GPIO_ACTIVE_HIGH>,
                       <&gpiob 4 GPIO_ACTIVE_HIGH>,
                       <&gpiob 10 GPIO_ACTIVE_HIGH>,
                       <&gpioa 8 GPIO_ACTIVE_HIGH>;
        sig-gpios = <&gpioa 1 GPIO_ACTIVE_HIGH>;
    };

    cd4067_2: cd4067_mux_2 {
        compatible = "vnd,cd4067-gpio-mux";
        status = "okay";
        select-gpios = <&gpiob 5 GPIO_ACTIVE_HIGH>,
                       <&gpiob 4 GPIO_ACTIVE_HIGH>,
                       <&gpiob 10 GPIO_ACTIVE_HIGH>,
                       <&gpioa 8 GPIO_ACTIVE_HIGH>;
        sig-gpios = <&gpioa 4 GPIO_ACTIVE_HIGH>;
    };

    cd4067_3: cd4067_mux_3 {
        compatible = "vnd,cd4067-gpio-mux";
        status = "okay";
        select-gpios = <&gpiob 5 GPIO_ACTIVE_HIGH>,
                       <&gpiob 4 GPIO_ACTIVE_HIGH>,
                       <&gpiob 10 GPIO_ACTIVE_HIGH>,
                       <&gpioa 8 GPIO_ACTIVE_HIGH>;
        sig-gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>;
    };
};

&i2c1 {
    status = "okay";

    pca9685_40: pca9685@40 {
        status = "okay";
        compatible = "nxp,pca9685-pwm";
        reg = <0x40>;
        #pwm-cells = <3>;
    };

    pca9685_41: pca9685@41 {
        status = "okay";
        compatible = "nxp,pca9685-pwm";
        reg = <0x41>;
        #pwm-cells = <3>;
