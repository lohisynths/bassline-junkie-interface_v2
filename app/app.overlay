        #pwm-cells = <3>;
    };

    pca9685_4a: pca9685@4a {
        status = "okay";
        compatible = "nxp,pca9685-pwm";
        reg = <0x4a>;
        #pwm-cells = <3>;
    };

    pca9685_4b: pca9685@4b {
