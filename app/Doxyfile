PROJECT_NAME           = "Bassline Junkie Interface"
PROJECT_BRIEF          = "Zephyr firmware for status LED, discrete GPIO inputs, PCA9685 LED outputs, CD4067 mux scanning, button decoding, quadrature encoder decoding, and knob-driven LED indication."
OUTPUT_DIRECTORY       = app/docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = app/docs/mainpage.md

INPUT                  = README.md \
                         app/docs/mainpage.md \
                         app/src/Button.h \
                         app/src/Button.cpp \
                         app/src/Encoder.h \
                         app/src/Encoder.cpp \
                         app/src/GPIO.h \
                         app/src/GPIO.cpp \
                         app/src/InputController.h \
                         app/src/InputController.cpp \
                         app/src/Knob.h \
                         app/src/Knob.cpp \
                         app/src/LEDS.h \
                         app/src/LEDS.cpp \
                         app/src/MUX.h \
                         app/src/MUX.cpp \
                         app/src/main.cpp \
                         cd4067/include/zephyr/drivers/mux/cd4067.h
FILE_PATTERNS          = *.md \
                         *.h \
                         *.cpp
RECURSIVE              = NO
EXCLUDE_SYMBOLS        = cd4067_driver_api

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
HAVE_DOT               = NO
