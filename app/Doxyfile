PROJECT_NAME           = "Bassline Junkie Interface"
PROJECT_BRIEF          = "Zephyr firmware for onboard status LED and PCA9685-driven LED outputs."
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

INPUT                  = README.md \
                         docs/mainpage.md \
                         src/LEDS.h \
                         src/LEDS.cpp \
                         src/main.cpp
FILE_PATTERNS          = *.md \
                         *.h \
                         *.cpp
RECURSIVE              = NO
EXCLUDE_SYMBOLS        =

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
